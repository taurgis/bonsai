    "config:get": {
      "aliases": [],
      "args": {
        "key": {
          "description": "The configuration key to read.",
          "name": "key",
          "required": true
        }
      },
      "description": "Print a config value. Without --global/--local, shows the merged effective value (flag > env > project > user > default).\n\nValid keys: storage.",
      "examples": [
        {
          "description": "Get the effective storage mode",
          "command": "<%= config.bin %> config get storage"
        },
        {
          "description": "Read only the project-level value",
          "command": "<%= config.bin %> config get storage --local"
        }
      ],
      "flags": {
        "json": {
          "description": "Format output as json.",
          "helpGroup": "GLOBAL",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        },
        "global": {
          "char": "g",
          "description": "Read from user-level config only.",
          "name": "global",
          "allowNo": false,
          "type": "boolean"
        },
        "local": {
          "aliases": [
            "project"
          ],
          "charAliases": [
            "p"
          ],
          "description": "Read from project-level config only.",
          "name": "local",
          "allowNo": false,
          "type": "boolean"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "config:get",
      "pluginAlias": "@taurgis/bonsai",
      "pluginName": "@taurgis/bonsai",
