      "flags": {
        "json": {
          "description": "Format output as json.",
          "helpGroup": "GLOBAL",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        },
        "tier": {
          "description": "freshness tier policy to evaluate against",
          "name": "tier",
          "default": "standard",
          "hasDynamicHelp": false,
