{
  "commands": {
    "fetch": {
      "aliases": [],
      "args": {
        "url": {
          "description": "The full HTTP/HTTPS URL of the web page to research.",
          "name": "url",
          "required": true
        }
      },
      "description": "Scrapes the specified URL, strips HTML boilerplate, converts the semantic payload into clean Markdown format, and caches the result locally using dynamic TTL rules.",
      "examples": [
        {
          "description": "Research a URL with detailed output, tagged with topic and tags",
          "command": "<%= config.bin %> https://docs.nestjs.com/ --topic \"Backend Frameworks\" --tags \"Node\" --tags \"NestJS\" --format detailed --ttl 30d"
        },
        {
          "description": "Research a volatile page with compressed output and short TTL, returned as JSON",
          "command": "<%= config.bin %> https://news.ycombinator.com/ --format compressed --ttl 2h --json"
        }
      ],
      "flags": {
        "json": {
          "description": "Format output as json.",
          "helpGroup": "GLOBAL",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        },
        "topic": {
          "char": "t",
          "description": "The main category/topic of the research for metadata tagging.",
          "name": "topic",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "tags": {
          "char": "g",
          "description": "Taxonomic tags for this research (can be repeated).",
          "name": "tags",
          "hasDynamicHelp": false,
          "multiple": true,
          "type": "option"
        },
        "format": {
          "char": "f",
          "description": "Desired data density.",
          "name": "format",
          "default": "compressed",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "compressed",
            "detailed"
          ],
          "type": "option"
        },
        "tier": {
          "description": "Freshness tier policy.",
          "name": "tier",
          "default": "standard",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "stable",
            "standard",
            "volatile"
          ],
          "type": "option"
        },
        "ttl": {
          "char": "l",
          "description": "Predicted lifespan of the data (e.g., \"2h\", \"7d\", \"3m\").",
          "name": "ttl",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "max-age": {
          "description": "Maximum age of cache to accept (e.g., \"1d\", \"30d\").",
          "name": "max-age",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "force": {
          "description": "Force a fresh fetch, ignoring any cached entries.",
          "name": "force",
          "allowNo": false,
          "type": "boolean"
        },
        "dry-run": {
          "description": "Perform validation and fetch without saving to local cache.",
          "name": "dry-run",
          "allowNo": false,
          "type": "boolean"
        },
        "allow-stale": {
          "description": "Allow serving stale cache if the remote server is unreachable.",
          "name": "allow-stale",
          "allowNo": false,
          "type": "boolean"
        },
        "rendered": {
          "description": "Force using a browser-rendered scraping path for dynamic pages.",
          "name": "rendered",
          "allowNo": false,
          "type": "boolean"
        },
        "storage": {
          "description": "Override where this result is cached (overrides configured default). Secret-bearing pages are always stored globally.",
          "name": "storage",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "global",
            "project"
          ],
          "type": "option"
        }
      },
      "hasDynamicHelp": false,
      "hidden": true,
      "hiddenAliases": [],
      "id": "fetch",
      "pluginAlias": "@taurgis/bonsai",
      "pluginName": "@taurgis/bonsai",
      "pluginType": "core",
      "strict": true,
      "summary": "An advanced, locally cached web research tool optimized for LLM ingestion.",
      "enableJsonFlag": true,
      "stdoutIsPrimaryData": true
    },
    "import": {
      "aliases": [],
      "args": {
        "url": {
          "description": "The single source URL of the page (only for single-source import).",
          "name": "url",
          "required": false
        }
      },
      "description": "Accepts a synthesized Markdown note via stdin and registers it under the single target URL or multiple source URLs.",
      "examples": [
        {
          "description": "Import detailed research for a single URL via stdin",
          "command": "echo \"# My Article\" | <%= config.bin %> import https://example.com/docs --stdin"
        },
        {
          "description": "Import research synthesized from multiple source URLs",
          "command": "echo \"# Synthesized\" | <%= config.bin %> import --stdin --topic \"React docs\" --source-url https://react.dev/a --source-url https://react.dev/b"
        },
        {
          "description": "Import research from a local Markdown file",
          "command": "<%= config.bin %> import https://example.com/docs --file path/to/notes.md"
        }
      ],
      "flags": {
        "json": {
          "description": "Format output as json.",
          "helpGroup": "GLOBAL",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        },
        "stdin": {
          "description": "Read Markdown from stdin.",
          "name": "stdin",
          "allowNo": false,
          "type": "boolean"
        },
        "file": {
          "description": "Path to a Markdown file containing research notes to import.",
          "name": "file",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "input-format": {
          "description": "Format of the input provided.",
          "name": "input-format",
          "default": "detailed",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "compressed",
            "detailed"
          ],
          "type": "option"
        },
        "topic": {
          "char": "t",
          "description": "The main topic for this research note.",
          "name": "topic",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "tags": {
          "char": "g",
          "description": "Taxonomic tags (can be repeated).",
          "name": "tags",
          "hasDynamicHelp": false,
          "multiple": true,
          "type": "option"
        },
        "tier": {
          "description": "Freshness tier policy.",
          "name": "tier",
          "default": "standard",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "stable",
            "standard",
            "volatile"
          ],
          "type": "option"
        },
        "source-url": {
          "description": "Repeated source URLs for multi-source import.",
          "name": "source-url",
          "hasDynamicHelp": false,
          "multiple": true,
          "type": "option"
        },
        "ttl": {
          "char": "l",
          "description": "Predicted lifespan of the data (e.g. \"24h\", \"7d\").",
          "name": "ttl",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "storage": {
          "description": "Override where this note is cached (overrides configured default). Secret-bearing notes are always stored globally.",
          "name": "storage",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "global",
            "project"
          ],
          "type": "option"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "import",
      "pluginAlias": "@taurgis/bonsai",
      "pluginName": "@taurgis/bonsai",
      "pluginType": "core",
      "strict": true,
      "summary": "Import agent-supplied clean Markdown notes into the local cache.",
      "enableJsonFlag": true,
      "stdoutIsPrimaryData": true
    },
    "inspect": {
      "aliases": [],
      "args": {
        "url": {
          "description": "The URL to inspect.",
          "name": "url",
          "required": true
        }
      },
      "description": "Inspects local storage and displays full frontmatter metadata for the URL (without printing the content body).",
      "flags": {
        "json": {
          "description": "Format output as json.",
          "helpGroup": "GLOBAL",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "inspect",
      "pluginAlias": "@taurgis/bonsai",
      "pluginName": "@taurgis/bonsai",
      "pluginType": "core",
      "strict": true,
      "summary": "Inspect cached research metadata for a URL.",
      "enableJsonFlag": true,
      "stdoutIsPrimaryData": true
    },
    "list": {
      "aliases": [],
      "args": {},
      "description": "Lists cached research artifacts, including metadata details like path, source count, freshness, token estimates, and quality metrics without printing full content.",
      "examples": [
        {
          "description": "List all cached entries",
          "command": "<%= config.bin %> list"
        },
        {
          "description": "List cached entries for a specific topic with JSON output",
          "command": "<%= config.bin %> list --topic \"React Suspense\" --json"
        },
        {
          "description": "List only fresh entries filtered by tags",
          "command": "<%= config.bin %> list --freshness fresh --tags node --tags url"
        }
      ],
      "flags": {
        "json": {
          "description": "Format output as json.",
          "helpGroup": "GLOBAL",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        },
        "topic": {
          "char": "t",
          "description": "Filter by exact topic (case-insensitive).",
          "name": "topic",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "tags": {
          "char": "g",
          "description": "Filter by tags (must match all tags specified).",
          "name": "tags",
          "hasDynamicHelp": false,
          "multiple": true,
          "type": "option"
        },
        "freshness": {
          "description": "Filter by freshness state.",
          "name": "freshness",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "fresh",
            "stale_grace",
            "stale_expired"
          ],
          "type": "option"
        },
        "artifact-type": {
          "description": "Filter by artifact type.",
          "name": "artifact-type",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "source",
            "research_note"
          ],
          "type": "option"
        },
        "capture-method": {
          "description": "Filter by capture method.",
          "name": "capture-method",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "static_fetch",
            "browser_fallback",
            "agent_supplied"
          ],
          "type": "option"
        },
        "limit": {
          "description": "Maximum number of results to return (default 50, max 100).",
          "name": "limit",
          "default": 50,
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "list",
      "pluginAlias": "@taurgis/bonsai",
      "pluginName": "@taurgis/bonsai",
      "pluginType": "core",
      "strict": true,
      "summary": "List cached research artifacts by metadata filters.",
      "enableJsonFlag": true,
      "stdoutIsPrimaryData": true
    },
    "prune": {
      "aliases": [],
      "args": {},
      "description": "Prunes cached research entries based on age, inactivity, or artifact type to free up disk space.",
      "examples": [
        {
          "description": "Perform a dry run of pruning entries older than 90 days",
          "command": "<%= config.bin %> prune --older-than 90d --dry-run"
        },
        {
          "description": "Actually prune entries older than 30 days that are source scrapes",
          "command": "<%= config.bin %> prune --older-than 30d --artifact-type source --yes"
        }
      ],
      "flags": {
        "json": {
          "description": "Format output as json.",
          "helpGroup": "GLOBAL",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        },
        "older-than": {
          "description": "Prune entries older than duration (e.g. \"30d\", \"90d\").",
          "name": "older-than",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "inactive": {
          "description": "Prune entries inactive (unvalidated/unfetched) for duration (e.g. \"14d\", \"30d\").",
          "name": "inactive",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "artifact-type": {
          "description": "Filter pruning to specific artifact type.",
          "name": "artifact-type",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "source",
            "research_note"
          ],
          "type": "option"
        },
        "dry-run": {
          "description": "List files that would be deleted without actually deleting them.",
          "name": "dry-run",
          "allowNo": false,
          "type": "boolean"
        },
        "yes": {
          "char": "y",
          "description": "Skip confirmation prompt and prune files.",
          "name": "yes",
          "allowNo": false,
          "type": "boolean"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "prune",
      "pluginAlias": "@taurgis/bonsai",
      "pluginName": "@taurgis/bonsai",
      "pluginType": "core",
      "strict": true,
      "summary": "Clean up old or inactive research cache entries.",
      "enableJsonFlag": true,
      "stdoutIsPrimaryData": true
    },
