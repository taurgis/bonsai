          "options": [
            "stable",
            "standard",
            "volatile"
          ],
          "type": "option"
        },
        "ttl": {
          "char": "l",
          "description": "custom TTL duration to evaluate against (e.g. \"2h\", \"7d\")",
          "name": "ttl",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "max-age": {
          "description": "maximum age of cache to accept (e.g. \"1d\", \"30d\")",
          "name": "max-age",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "status",
      "pluginAlias": "@taurgis/bonsai",
      "pluginName": "@taurgis/bonsai",
      "pluginType": "core",
      "strict": false,
