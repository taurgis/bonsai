      "enableJsonFlag": false,
      "jsonEnvelope": false,
      "stdoutIsPrimaryData": true,
      "isESM": true,
      "relativePath": [
        "dist",
        "commands",
        "research",
        "inspect.js"
      ]
    },
    "research:search": {
      "aliases": [],
      "args": {
        "query": {
          "description": "The search query containing terms to match.",
          "name": "query",
          "required": true
        }
      },
      "description": "Scans the local research cache database and ranks matching entries based on topic, tags, source URLs, summary, and content.",
      "flags": {
        "json": {
          "description": "Return the output as a machine-readable JSON object.",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        },
        "topic": {
          "char": "t",
          "description": "Filter results by exact topic (case-insensitive).",
          "name": "topic",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "tags": {
          "char": "g",
          "description": "Filter results by tags (must match all tags specified).",
          "name": "tags",
          "hasDynamicHelp": false,
          "multiple": true,
          "type": "option"
        },
        "artifact-type": {
          "description": "Filter results by artifact type.",
          "name": "artifact-type",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "source",
            "research_note"
          ],
          "type": "option"
        },
        "limit": {
          "description": "Maximum number of results to return (default 10, max 50).",
          "name": "limit",
          "default": 10,
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "include-stale": {
          "description": "Include stale expired cache entries in the search results.",
          "name": "include-stale",
          "allowNo": false,
          "type": "boolean"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "research:search",
      "pluginAlias": "forward-nexus-plugin-research",
      "pluginName": "forward-nexus-plugin-research",
      "pluginType": "core",
      "strict": true,
      "summary": "Search locally cached research artifacts by keywords.",
      "enableJsonFlag": false,
      "jsonEnvelope": false,
      "stdoutIsPrimaryData": true,
      "isESM": true,
      "relativePath": [
        "dist",
        "commands",
        "research",
        "search.js"
      ]
    },
