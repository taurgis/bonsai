          "description": "Remove from project-level config (.bonsai.json in cwd).",
          "name": "local",
          "allowNo": false,
          "type": "boolean"
        },
        "dry-run": {
          "description": "Show what would be removed without saving.",
          "name": "dry-run",
          "allowNo": false,
          "type": "boolean"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "config:unset",
      "pluginAlias": "@taurgis/bonsai",
      "pluginName": "@taurgis/bonsai",
      "pluginType": "core",
      "strict": true,
