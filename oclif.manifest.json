{
  "commands": {
    "research": {
      "aliases": [],
      "args": {
        "url": {
          "description": "The full HTTP/HTTPS URL of the web page to research.",
          "name": "url",
          "required": true
        }
      },
      "description": "Scrapes the specified URL, strips HTML boilerplate, converts the semantic payload into clean Markdown format, and caches the result locally using dynamic TTL rules.",
      "examples": [
        {
          "description": "Research a URL with detailed output, tagged with topic and tags",
          "command": "<%= config.bin %> research https://docs.nestjs.com/ --topic \"Backend Frameworks\" --tags \"Node\" --tags \"NestJS\" --format detailed --ttl 30d"
        },
        {
          "description": "Research a volatile page with compressed output and short TTL, returned as JSON",
          "command": "<%= config.bin %> research https://news.ycombinator.com/ --format compressed --ttl 2h --json"
        }
      ],
      "flags": {
        "json": {
          "description": "Return the output as a machine-readable JSON object.",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        },
        "topic": {
          "char": "t",
          "description": "The main category/topic of the research for metadata tagging.",
          "name": "topic",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "tags": {
          "char": "g",
          "description": "Taxonomic tags for this research (can be repeated).",
          "name": "tags",
          "hasDynamicHelp": false,
          "multiple": true,
          "type": "option"
        },
        "format": {
          "char": "f",
          "description": "Desired data density.",
          "name": "format",
          "default": "compressed",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "compressed",
            "detailed"
          ],
          "type": "option"
        },
        "tier": {
          "description": "Freshness tier policy.",
          "name": "tier",
          "default": "standard",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "stable",
            "standard",
            "volatile"
          ],
          "type": "option"
        },
        "ttl": {
          "char": "l",
          "description": "Predicted lifespan of the data (e.g., \"2h\", \"7d\", \"3m\").",
          "name": "ttl",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "max-age": {
          "description": "Maximum age of cache to accept (e.g., \"1d\", \"30d\").",
          "name": "max-age",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "force": {
          "description": "Force a fresh fetch, ignoring any cached entries.",
          "name": "force",
          "allowNo": false,
          "type": "boolean"
        },
        "dry-run": {
          "description": "Perform validation and fetch without saving to local cache.",
          "name": "dry-run",
          "allowNo": false,
          "type": "boolean"
        },
        "allow-stale": {
          "description": "Allow serving stale cache if the remote server is unreachable.",
          "name": "allow-stale",
          "allowNo": false,
          "type": "boolean"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "research",
      "pluginAlias": "forward-nexus-plugin-research",
      "pluginName": "forward-nexus-plugin-research",
      "pluginType": "core",
      "strict": true,
      "summary": "An advanced, locally cached web research tool optimized for LLM ingestion.",
      "enableJsonFlag": false,
      "jsonEnvelope": false,
      "stdoutIsPrimaryData": true,
      "isESM": true,
      "relativePath": [
        "dist",
        "commands",
        "research.js"
      ]
    },
    "research:import": {
      "aliases": [],
      "args": {
        "url": {
          "description": "The single source URL of the page (only for single-source import).",
          "name": "url",
          "required": false
        }
      },
      "description": "Accepts a synthesized Markdown note via stdin and registers it under the single target URL or multiple source URLs.",
      "examples": [
        {
          "description": "Import detailed research for a single URL via stdin",
          "command": "echo \"# My Article\" | <%= config.bin %> research import https://example.com/docs --stdin"
        },
        {
          "description": "Import research synthesized from multiple source URLs",
          "command": "echo \"# Synthesized\" | <%= config.bin %> research import --stdin --topic \"React docs\" --source-url https://react.dev/a --source-url https://react.dev/b"
        }
      ],
      "flags": {
        "json": {
          "description": "Return the output as a machine-readable JSON object.",
          "name": "json",
          "allowNo": false,
          "type": "boolean"
        },
        "stdin": {
          "description": "Read Markdown from stdin.",
          "name": "stdin",
          "allowNo": false,
          "type": "boolean"
        },
        "input-format": {
          "description": "Format of the input provided.",
          "name": "input-format",
          "default": "detailed",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "compressed",
            "detailed"
          ],
          "type": "option"
        },
        "topic": {
          "char": "t",
          "description": "The main topic for this research note.",
          "name": "topic",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "tags": {
          "char": "g",
          "description": "Taxonomic tags (can be repeated).",
          "name": "tags",
          "hasDynamicHelp": false,
          "multiple": true,
          "type": "option"
        },
        "tier": {
          "description": "Freshness tier policy.",
          "name": "tier",
          "default": "standard",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "stable",
            "standard",
            "volatile"
          ],
          "type": "option"
        },
        "source-url": {
          "description": "Repeated source URLs for multi-source import.",
          "name": "source-url",
          "hasDynamicHelp": false,
          "multiple": true,
          "type": "option"
        },
        "ttl": {
          "char": "l",
          "description": "Predicted lifespan of the data (e.g. \"24h\", \"7d\").",
          "name": "ttl",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        }
      },
      "hasDynamicHelp": false,
      "hiddenAliases": [],
      "id": "research:import",
      "pluginAlias": "forward-nexus-plugin-research",
      "pluginName": "forward-nexus-plugin-research",
      "pluginType": "core",
      "strict": true,
      "summary": "Import agent-supplied clean Markdown notes into the local cache.",
      "enableJsonFlag": false,
      "jsonEnvelope": false,
      "stdoutIsPrimaryData": true,
      "isESM": true,
      "relativePath": [
        "dist",
        "commands",
        "research",
        "import.js"
      ]
    },
    "research:inspect": {
      "aliases": [],
      "args": {
        "url": {
          "description": "The URL to inspect.",
          "name": "url",
          "required": true
        }
      },
      "description": "Inspects local storage and displays full frontmatter metadata for the URL (without printing the content body).",
      "flags": {
